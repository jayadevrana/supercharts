# ============================================
# SuperCharts — environment variables
# Copy to .env.local (web) and .env (api/ingestion)
# ============================================

# ---- App URLs ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# Zerodha Kite Indian-market data (read-only). Obtain KITE_ACCESS_TOKEN via Kite's
# official interactive login redirect; it expires daily. Never put passwords, TOTP
# seeds, API secrets, or order credentials here.
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Extra origins allowed by the API's CORS check, comma-separated.
# Leave empty in dev — NEXT_PUBLIC_APP_URL is allowed automatically.
CORS_ORIGINS=

# ---- API bind ----
# Loopback-only by default. Set HOST=0.0.0.0 only when the API must be reachable
# from another machine on the LAN.
HOST=127.0.0.1
PORT=4000

# ---- Auth ----
# IMPORTANT: never deploy with the literal "replace-with-…" string. Generate per
# environment with `openssl rand -hex 32` and store in your secrets manager.
AUTH_SECRET=replace-with-32-byte-random-hex
AUTH_TRUST_HOST=true

# ---- Encryption (provider creds, etc) ----
# IMPORTANT: see note above. Treat as a secret and rotate.
ENCRYPTION_KEY=replace-with-32-byte-random-hex

# ---- Database ----
# The current build accepts ONLY `file:` URLs. Non-file schemes throw at startup
# rather than silently falling back to SQLite. Postgres lands in Phase 11 (Auth.js).
DATABASE_URL=file:./data/supercharts.sqlite

# ---- Local infra (docker-compose) ----
# All published ports bind to 127.0.0.1 by default. Override to 0.0.0.0 only
# intentionally — passwords here are throwaway dev creds, never reuse in prod.
DEV_BIND_HOST=127.0.0.1
POSTGRES_PASSWORD=supercharts
REDIS_PASSWORD=supercharts

# ---- Redis (optional in dev; in-memory fallback if missing) ----
REDIS_URL=

# ---- ClickHouse (optional in dev; SQLite/in-memory fallback) ----
CLICKHOUSE_HOST=
CLICKHOUSE_USER=default
# Must match the value used by the compose file (defaults to `supercharts`).
CLICKHOUSE_PASSWORD=supercharts
CLICKHOUSE_DATABASE=supercharts

# ---- Crypto providers ----
BINANCE_ENABLED=true
# Binance public market data — no key required.
COINBASE_ENABLED=false
KRAKEN_ENABLED=false

# ---- Forex providers ----
OANDA_ENABLED=false
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
# OANDA_ENV options: practice | live

TWELVEDATA_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=

# ---- Metadata / fallback ----
COINGECKO_API_KEY=

# ---- News ----
CRYPTOPANIC_API_KEY=
NEWSAPI_KEY=
GDELT_ENABLED=true
# GDELT requires no key.

# ---- Billing (Stripe) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_6_MONTH=
STRIPE_PRICE_ID_12_MONTH=

# ---- Feature flags ----
ENABLE_REPLAY=true
ENABLE_FOOTPRINT=true
ENABLE_HEATMAP=true
ENABLE_DEEP_TRADES=true

# ---- MT5 EA bridge (custom TCP socket carrying NDJSON) ----
# Same loopback default as the HTTP API. Override only when the EA runs on a
# different host than the API.
MT5_BRIDGE_PORT=7878
MT5_BRIDGE_HOST=127.0.0.1

# ---- Logging ----
LOG_LEVEL=info
NODE_ENV=development
