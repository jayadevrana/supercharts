{
  "name": "supercharts",
  "version": "0.1.0",
  "private": true,
  "description": "SuperCharts — institutional-grade charting terminal for crypto and forex",
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "dev:web": "pnpm --filter @supercharts/web dev",
    "dev:api": "pnpm --filter @supercharts/api dev",
    "dev:ingestion": "pnpm --filter @supercharts/ingestion dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf node_modules dist .next && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.2"
}
