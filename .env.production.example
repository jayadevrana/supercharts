# SuperCharts — PRODUCTION env template.
#
# On the VM: copy this to a root `.env` (never commit it), fill the values, then start with pm2.
#   cp .env.production.example .env   &&   nano .env
# The API auto-loads this root `.env` (apps/api/src/env.ts walks up to pnpm-workspace.yaml).
# Shell environment variables always win over the file, so secrets can also come from the shell.
#
# The web app (Next.js) needs NOTHING here for a bare-IP deploy: its /api rewrite defaults to
# http://localhost:4000 (correct on the VM) and the browser derives the WebSocket URL from its own
# origin. Only set NEXT_PUBLIC_* (in apps/web/.env.production) once you put it behind a domain.

# ── Networking ────────────────────────────────────────────────────────────────
# Bind the API on all interfaces so the browser can reach the WebSocket on :4000 directly
# (bare-IP mode). Behind Caddy on a domain, set HOST=127.0.0.1 and close the :4000 firewall.
HOST=0.0.0.0
PORT=4000
# Public origin of the web app — used for CORS. Bare IP first; swap to https://yourdomain later.
NEXT_PUBLIC_APP_URL=http://35.200.208.191:3000
CORS_ORIGINS=http://35.200.208.191:3000

# ── Data ──────────────────────────────────────────────────────────────────────
# node:sqlite file (single-node). WAL is enabled by the app. Back this file up nightly.
DATABASE_URL=file:./data/supercharts.sqlite

# ── Secrets (fill these — do NOT paste them into any chat) ─────────────────────
AUTH_SECRET=          # long random string:  openssl rand -hex 32
ENCRYPTION_KEY=       # long random string:  openssl rand -hex 32

# ── Auth (Google OAuth + email/password) ───────────────────────────────────────
# AUTH_ENABLED defaults to on. Set to 0 ONLY for single-user/local dev to fall back to the
# legacy `demo` account when no session cookie is present.
# AUTH_ENABLED=1
# Google OAuth Web client (console.cloud.google.com → Credentials). The redirect URI you
# register must be exactly:  https://supercharting.com/api/auth/google/callback
# The CLIENT ID is public; keep the CLIENT SECRET out of chat — paste it here on the box only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Market data providers ──────────────────────────────────────────────────────
# Binance is keyless — but its API is IP-blocked from the US. This VM is in asia-south1
# (Mumbai) precisely so Binance works. Do NOT move the VM to a us-* region.
BINANCE_ENABLED=1
# OANDA forex (optional — your own practice/live token; leave blank to use Yahoo fallback).
OANDA_ENABLED=0
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
# Optional keyless/keyed news + macro (safe to leave blank for a first deploy).
GDELT_ENABLED=1
CRYPTOPANIC_API_KEY=

# ── Telegram (your alert delivery — this VM is a FRESH instance) ────────────────
# Leave blank to start clean and add your bot from the terminal UI (Alerts → Telegram).
# Your existing local alerts are unaffected; this is a separate deployment.
# (No single TELEGRAM_TOKEN var — bots are stored per-user in the DB via the UI.)

# ── MT5 bridge ─────────────────────────────────────────────────────────────────
MT5_BRIDGE_PORT=7878
# 127.0.0.1 = only local EAs. Set 0.0.0.0 to accept EAs from other machines (token-gated);
# if you do, restrict the :7878 firewall rule to your MT5 client IPs.
MT5_BRIDGE_HOST=127.0.0.1

# ── Billing (not live yet — Phase C) ───────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Feature flags ──────────────────────────────────────────────────────────────
ENABLE_REPLAY=1
LOG_LEVEL=info
